@startuml FireDetectionApp_FlowDiagram

skinparam backgroundColor #ffffff
skinparam ActivityBackgroundColor #ffffff
skinparam ActivityBorderColor #333333
skinparam ActivityFontColor #000000
skinparam ActivityFontSize 12
skinparam ActivityArrowColor #333333
skinparam ActivityArrowFontColor #555555
skinparam ActivityArrowFontSize 10
skinparam ActivityStartColor #333333
skinparam ActivityEndColor #333333
skinparam ActivityDiamondBackgroundColor #fffdf0
skinparam ActivityDiamondBorderColor #333333
skinparam ActivityDiamondFontColor #000000
skinparam PartitionBackgroundColor #f9f9f9
skinparam PartitionBorderColor #555555
skinparam PartitionFontColor #000000
skinparam shadowing false
skinparam defaultFontName Arial
skinparam linetype ortho

title Fire Detection System - Application Flow

' ─────────────────────────────────────────
' STARTUP
' ─────────────────────────────────────────
start

:Launch application;
:Load YOLO model\n(fire.pt);

if (fire.pt found?) then (no)
    :Print error to console;
    :Set exit_code = 1;
else (yes)
    :Model loaded successfully;

    :Initialise MainWindow;
    :Initialise Detector;
    :Initialise CameraManager\nwith default Webcam 0;
    :Initialise LogPanel;
    :Display UI;

    ' ─────────────────────────────────────────
    ' SOURCE SELECTION
    ' ─────────────────────────────────────────
    partition "Source Management" {

        :User selects or adds a source;

        if (Source type?) then (webcam)
            :Use VideoCapture(index);
        else if (IP camera) then (yes)
            :Use RTSP URL string;
        else if (video file) then (yes)
            :Use file path\n(.mp4 .avi .mov .mkv);
        else (image file)
            :Use cv2.imread()\n(.png .jpg etc.);
        endif

        :Store Camera object\nin CameraManager list;

    }

    ' ─────────────────────────────────────────
    ' STARTING THE FEED
    ' ─────────────────────────────────────────
    partition "Feed Startup" {

        :User presses Start;
        :Call camera.open();

        if (Camera opened?) then (no)
            :Show error in status bar;
            :Return to source selection;
        else (yes)

            if (Source type?) then (image file)
                :Set FPS = 1;
            else if (video file) then (yes)
                :Read FPS from\nfile metadata;
            else (live camera)
                :Measure real FPS\n(sample 30 frames);
            endif

            :Calculate timer interval\n= 1000 / fps ms;
            :Start QTimer;
            :Update status bar\nwith FPS and resolution;

        endif

    }

    ' ─────────────────────────────────────────
    ' MAIN FRAME LOOP
    ' ─────────────────────────────────────────
    partition "Frame Loop  (runs every N ms)" {

        repeat

            :QTimer fires;
            :camera.read() -> frame;

            if (Frame read OK?) then (no)
                :Show feed ended error;
                :Stop feed;
                break
            else (yes)
            endif

            if (Debug mode active?) then (yes)
                :FrameTimer.start();
            endif

            :model.track(\n  frame,\n  conf=0.9,\n  iou=0.5,\n  tracker=bytetrack\n);

            if (Debug mode active?) then (yes)
                :FrameTimer.stop();
                :Print detections\nand inference time;
            endif

            :Get annotated frame\nand detected boxes;

            if (Detections found?) then (yes)

                :For each detected object\nextract track_id and label;

                if (track_id already\nin tracked_objects?) then (no)
                    :Create new TrackedObject\n(track_id, label, timestamp);
                    :Add to tracked_objects dict;
                    :LogPanel.add_entry()\nwith PC timestamp;
                    :Emit fire_detected signal;
                else (yes)
                    :Call tracked_object.update()\n(last_seen, frames++);
                    if (frames % 30 == 0?) then (yes)
                        :LogPanel.update_entry()\nrefresh last seen time;
                    endif
                endif

                :Update info label\n"Fire in frame: N  Total: M";

            else (no)
                :Update info label\n"Fire in frame: 0";
            endif

            :frame_to_qimage(annotated);
            :fit_pixmap_to_label();
            :Render frame to video_label;

        repeat while (User presses Stop?) is (no)
        -> yes;

    }

    ' ─────────────────────────────────────────
    ' ALERT FLOW
    ' ─────────────────────────────────────────
    partition "Alert Flow" {

        if (fire_detected\nsignal received?) then (yes)

            if (Flash timer\nalready running?) then (yes)
                :Ignore, already flashing;
            else (no)
                :Reset flash_count = 0;
                :Start flash QTimer\n(every 500ms);

                repeat
                    :QApplication.alert();
                    :flash_count++;
                repeat while (flash_count < 10?) is (yes)
                -> no;

                :Stop flash timer;
            endif

        endif

    }

    ' ─────────────────────────────────────────
    ' LOG MANAGEMENT
    ' ─────────────────────────────────────────
    partition "Log Management" {

        if (User presses Clear Log?) then (yes)
            :LogPanel.clear();
            :Detector.clear()\nreset tracked_objects;
            :Reset info label;
        endif

    }

    ' ─────────────────────────────────────────
    ' FEED SHUTDOWN
    ' ─────────────────────────────────────────
    partition "Feed Shutdown" {

        :Stop frame QTimer;
        :Stop flash QTimer;
        :camera.release();
        :Reset video display;
        :Show total events\nin status bar;

        if (User switches source?) then (yes)
            :Go back to Source Management;
        endif

    }

    ' ─────────────────────────────────────────
    ' APP SHUTDOWN
    ' ─────────────────────────────────────────
    :User closes window;
    :closeEvent() called;
    :stop_feed() cleanup;
    :Set exit_code = 0;

endif

' single exit point
:Exit application\nwith exit_code;
stop

@enduml